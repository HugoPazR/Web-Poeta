rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin status lives in its own collection instead of a hardcoded email, so more than
    // one account can be an admin. Docs there are only ever created by the site owner
    // directly in the Firebase Console (allow write: if false below) — never by the client
    // SDK — so a user can never grant themselves admin by writing to their own profile.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // The five reaction emojis offered in the UI (src/data/poems.js) — keep in sync manually.
    function isKnownEmoji(e) {
      return e in ['❤️', '😢', '🔥', '🤍', '✨'];
    }

    // Matches the exact shape storage.js's addComment() writes: { id, poemId, name, text, timestamp }.
    // Rejects anything else so malformed writes (e.g. name/text as a non-string) can't crash the
    // Comments UI for every visitor, and caps sizes against spam/storage abuse.
    function isValidComment(data) {
      return data.keys().hasOnly(['id', 'poemId', 'name', 'text', 'timestamp'])
        && data.id is string && data.id.size() > 0 && data.id.size() <= 50
        && data.poemId is string && data.poemId.size() > 0 && data.poemId.size() <= 100
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.timestamp is number;
    }

    // Matches { counts: { <emoji>: number } } from storage.js's addReaction()/incrementFields().
    function isValidReactionCounts(data) {
      return data.keys().hasOnly(['counts'])
        && data.counts is map
        && data.counts.keys().hasOnly(['❤️', '😢', '🔥', '🤍', '✨'])
        && (!('❤️' in data.counts) || (data.counts['❤️'] is number && data.counts['❤️'] >= 0))
        && (!('😢' in data.counts) || (data.counts['😢'] is number && data.counts['😢'] >= 0))
        && (!('🔥' in data.counts) || (data.counts['🔥'] is number && data.counts['🔥'] >= 0))
        && (!('🤍' in data.counts) || (data.counts['🤍'] is number && data.counts['🤍'] >= 0))
        && (!('✨' in data.counts) || (data.counts['✨'] is number && data.counts['✨'] >= 0));
    }

    // Matches { poemId, emoji, timestamp } from storage.js's addReaction().
    function isValidReactionLog(data) {
      return data.keys().hasOnly(['poemId', 'emoji', 'timestamp'])
        && data.poemId is string && data.poemId.size() > 0 && data.poemId.size() <= 100
        && data.emoji is string && isKnownEmoji(data.emoji)
        && data.timestamp is number;
    }

    // Matches { views: number } from storage.js's addView().
    function isValidViews(data) {
      return data.keys().hasOnly(['views'])
        && data.views is number
        && data.views >= 0
        && data.views < 100000000;
    }

    // Matches { poemId, date, views } from storage.js's addView() daily bucket write.
    // The doc id must be "<poemId>_<date>", which is what the client always sets it to.
    function isValidViewsDaily(data, id) {
      return data.keys().hasOnly(['poemId', 'date', 'views'])
        && data.poemId is string && data.poemId.size() > 0 && data.poemId.size() <= 100
        && data.date is string && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.views is number && data.views >= 0 && data.views < 100000000
        && id == (data.poemId + '_' + data.date);
    }

    // Matches { email, createdAt } from storage.js's subscribeToNewsletter(). The doc id
    // must equal the email itself, which is what the client always sets it to.
    function isValidSubscriber(data, id) {
      return data.keys().hasOnly(['email', 'createdAt'])
        && data.email is string && data.email == id
        && data.email.matches('^\\S+@\\S+[.]\\S+$')
        && data.createdAt is number;
    }

    // Poems, comments, reactions and views are the public content of this poetry site,
    // so anyone can read them. Only the poet's own Firebase Auth account (verified via
    // the signed ID token, not just a client-side check) may publish/delete poems or
    // moderate comments.
    match /poems/{poemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidComment(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /reactions/{poemId} {
      allow read: if true;
      allow write: if isValidReactionCounts(request.resource.data);
    }

    match /reaction_log/{logId} {
      allow read: if true;
      allow create: if isValidReactionLog(request.resource.data);
    }

    match /views/{poemId} {
      allow read: if true;
      allow write: if isValidViews(request.resource.data);
    }

    match /views_daily/{entryId} {
      allow read: if true;
      allow write: if isValidViewsDaily(request.resource.data, entryId);
    }

    // Each account can only read/write its own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Whether a given account is an admin. Existence of the doc (id = the account's uid) is
    // the only thing that matters — content can be empty. Only the account itself may read
    // its own status (so the UI can show/hide the admin panel link); nobody may write via the
    // client SDK, so the only way to add or remove an admin is manually in the Firebase Console.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Newsletter signups: anyone can subscribe (or re-subscribe, which just updates the
    // timestamp since the doc id is the email), but the list itself isn't publicly readable.
    match /subscribers/{subscriberId} {
      allow read, delete: if isAdmin();
      allow create, update: if isValidSubscriber(request.resource.data, subscriberId);
    }
  }
}
