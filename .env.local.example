# Copy this file to .env.local and fill with your Firebase project values
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Example: VITE_FIREBASE_PROJECT_ID=my-firebase-project

# EmailJS (contact form) — create a free account at https://www.emailjs.com
# 1. Add an Email Service (connect your Gmail/Outlook/etc.) -> copy its Service ID
# 2. Create an Email Template with variables {{from_name}}, {{reply_to}}, {{message}} -> copy its Template ID
# 3. Account > General -> copy your Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# EmailJS (new-poem notification) — same account as above, second template
# 1. Create another Email Template with variables {{to_email}}, {{poem_title}}, {{poem_excerpt}}, {{poem_url}}
# 2. In that template's settings, set "To Email" to {{to_email}} (not your own address!)
# 3. Copy its Template ID
VITE_EMAILJS_NOTIFY_TEMPLATE_ID=

# Google reCAPTCHA v2 (registration form bot protection) — register a site at
# https://www.google.com/recaptcha/admin
# 1. Choose reCAPTCHA v2 -> "I'm not a robot" Checkbox
# 2. Add your domain(s) and "localhost" for local dev
# 3. Copy the Site Key -> VITE_RECAPTCHA_SITE_KEY (safe to expose to the client)
# 4. Copy the Secret Key -> RECAPTCHA_SECRET_KEY (server-only — do NOT prefix with VITE_,
#    add it in the Vercel dashboard's Environment Variables too, never commit it or
#    expose it to the client bundle)
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
